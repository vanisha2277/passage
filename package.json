{
  "name": "passage",
  "private": true,
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"npm run dev --prefix backend\" \"npm run dev --prefix frontend\"",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "redis:up": "docker compose up -d redis",
    "redis:dev": "node scripts/dev-redis.mjs",
    "redis:down": "docker compose down",
    "verify:redis": "npm run verify:redis --prefix frontend",
    "verify:session-tokens": "node backend/scripts/verify-session-tokens.mjs",
    "verify:translate": "npm run verify:translate --prefix frontend",
    "phoenix:serve": ".phoenix-venv/bin/python -m phoenix.server.main serve",
    "score:phoenix": "npm run score:phoenix --prefix backend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "redis-memory-server": "^0.16.1"
  }
}
